# GPS Configuration
# Copy to .env and customize

# Database name (default: gps.db)
# GPS_DB_NAME=gps.db

# Tab-to-org mapping (JSON) — keys are XLSX sheet names, values are [org_key, org_name] pairs
# GPS_TAB_ORG_MAP='{"Platform - Team Breakdown": ["platform", "Platform"]}'

# XLSX sheet name containing Jira-to-Scrum-team mappings
# GPS_JIRA_SCRUM_REF_TAB=Jira and Scrum teams

# Optional: Jira API integration (for live issue sync, not needed for CSV import)
# JIRA_API_TOKEN=
# JIRA_URL=
